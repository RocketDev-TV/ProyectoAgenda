                                   th:field="*{name}"
                                   class="form-control"
                                   th:classappend="${#fields.hasErrors('name')} ? ' is-invalid'"
                                   placeholder="ej. María"/>
                            <div class="invalid-feedback" th:if="${#fields.hasErrors('name')}"
                                 th:errors="*{name}"></div>
                        </div>

                        <!-- Apellidos -->
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label for="lastName" class="form-label">Primer Apellido *</label>
                                <input type="text" id="lastName"
                                       th:field="*{lastName}"
                                       class="form-control"
                                       th:classappend="${#fields.hasErrors('lastName')} ? ' is-invalid'"
                                       placeholder="ej. García"/>
                                <div class="invalid-feedback" th:if="${#fields.hasErrors('lastName')}"
                                     th:errors="*{lastName}"></div>
                            </div>
                            <div class="col-sm-6">
                                <label for="secondLastName" class="form-label">
                                    Segundo Apellido <span class="text-muted fw-normal">(opcional)</span>
                                </label>
                                <input type="text" id="secondLastName"
                                       th:field="*{secondLastName}"
                                       class="form-control"
                                       placeholder="ej. López"/>
                            </div>
                        </div>

                        <!-- Username -->
                        <div class="mb-4">
                            <label for="username" class="form-label">
                                <i class="bi bi-at text-brand me-1"></i>Nombre de Usuario *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0">
                                    <i class="bi bi-at"></i>
                                </span>
                                <input type="text" id="username"
                                       th:field="*{username}"
                                       class="form-control border-start-0"
                                       th:classappend="${#fields.hasErrors('username')} ? ' is-invalid'"
                                       placeholder="mi_usuario"
                                       autocomplete="username"/>
                                <div class="invalid-feedback" th:if="${#fields.hasErrors('username')}"
                                     th:errors="*{username}"></div>
                            </div>
                        </div>

                        <!-- Info: no se edita contraseña -->
                        <div class="alert alert-light border d-flex gap-2 align-items-start py-2 mb-4" role="alert">
                            <i class="bi bi-info-circle-fill text-brand mt-1 flex-shrink-0"></i>
