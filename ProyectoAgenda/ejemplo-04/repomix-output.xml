<file path="src/main/resources/templates/users/edit.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<head th:replace="~{fragments/layout :: head('Editar Perfil')}">
</head>

<body>
<div th:replace="~{fragments/layout :: navbar}"></div>

<main class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-9 col-lg-7 col-xl-6">

            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb small">
                    <li class="breadcrumb-item">
                        <a th:href="@{/users}" class="text-brand text-decoration-none">
                            <i class="bi bi-people me-1"></i>Usuarios
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Editar Perfil</li>
                </ol>
            </nav>

            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-person-fill-gear me-2"></i>Editar Perfil de Usuario</h5>
                </div>
                <div class="card-body p-4">
                    <!--
                        PUT via hidden _method.
                        El ${id} viene del controlador: model.addAttribute("id", ...).
                        El DTO es UpdateUserDto (sin campo password).
                    -->
                    <form th:action="@{/users/{id}(id=${id})}"
                          th:object="${userDto}"
                          method="POST">
                        <input type="hidden" name="_method" value="PUT"/>

                        <!-- Nombre -->
                        <div class="mb-3">
                            <label for="name" class="form-label">
                                <i class="bi bi-person text-brand me-1"></i>Nombre *
                            </label>
                            <input type="text" id="name"
                                   th:field="*{name}"
                                   class="form-control"
                                   th:classappend="${#fields.hasErrors('name')} ? ' is-invalid'"
                                   placeholder="ej. María"/>
                            <div class="invalid-feedback" th:if="${#fields.hasErrors('name')}"
                                 th:errors="*{name}"></div>
                        </div>

                        <!-- Apellidos -->
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label for="lastName" class="form-label">Primer Apellido *</label>
                                <input type="text" id="lastName"
                                       th:field="*{lastName}"
                                       class="form-control"
                                       th:classappend="${#fields.hasErrors('lastName')} ? ' is-invalid'"
                                       placeholder="ej. García"/>
                                <div class="invalid-feedback" th:if="${#fields.hasErrors('lastName')}"
                                     th:errors="*{lastName}"></div>
                            </div>
                            <div class="col-sm-6">
                                <label for="secondLastName" class="form-label">
                                    Segundo Apellido <span class="text-muted fw-normal">(opcional)</span>
                                </label>
                                <input type="text" id="secondLastName"
                                       th:field="*{secondLastName}"
                                       class="form-control"
                                       placeholder="ej. López"/>
                            </div>
                        </div>

                        <!-- Username -->
                        <div class="mb-4">
                            <label for="username" class="form-label">
                                <i class="bi bi-at text-brand me-1"></i>Nombre de Usuario *
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0">
                                    <i class="bi bi-at"></i>
                                </span>
                                <input type="text" id="username"
                                       th:field="*{username}"
                                       class="form-control border-start-0"
                                       th:classappend="${#fields.hasErrors('username')} ? ' is-invalid'"
                                       placeholder="mi_usuario"
                                       autocomplete="username"/>
                                <div class="invalid-feedback" th:if="${#fields.hasErrors('username')}"
                                     th:errors="*{username}"></div>
                            </div>
                        </div>

                        <!-- Contraseña (dejar vacío para no cambiarla) -->
                        <div class="mb-4">
                            <label for="password" class="form-label">
                                <i class="bi bi-shield-lock text-brand me-1"></i>Nueva Contraseña
                                <span class="text-muted fw-normal">(opcional)</span>
                            </label>
                            <div class="position-relative">
                                <input type="password" id="password"
                                       th:field="*{password}"
                                       class="form-control"
                                       style="padding-right: 2.5rem;"
                                       placeholder="Dejar vacío para no cambiarla"
                                       autocomplete="new-password"/>
                                <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 text-secondary fs-5"
                                   id="togglePassword" style="cursor: pointer; z-index: 10;"></i>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-brand px-4">
                                <i class="bi bi-floppy me-2"></i>Guardar Cambios
                            </button>
                            <a th:href="@{/welcome}" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-1"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</main>

<div th:replace="~{fragments/layout :: footer}"></div>
<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
</html>
</file>

<file path="src/main/resources/templates/users/index.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<head th:replace="~{fragments/layout :: head('Usuarios')}">
</head>

<body>
<div th:replace="~{fragments/layout :: navbar}"></div>

<main class="container py-4">

    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 page-header">
        <div>
            <h3><i class="bi bi-person-lines-fill text-brand me-2"></i>Usuarios del Sistema</h3>
            <p>Listado de todas las cuentas registradas</p>
        </div>
        <a th:href="@{/register/new}" class="btn btn-brand">
            <i class="bi bi-person-plus-fill me-2"></i>Nuevo Usuario
        </a>
    </div>

    <!-- Tabla -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th class="ps-4">Usuario</th>
                        <th class="d-none d-md-table-cell">Apellidos</th>
                        <th class="text-center pe-4" style="width:130px;">Acciones</th>
                    </tr>
                    </thead>
                    <tbody>

                    <!-- Sin usuarios -->
                    <tr th:if="${#lists.isEmpty(personas)}">
                        <td colspan="3">
                            <div class="empty-state">
                                <i class="bi bi-people"></i>
                                <strong class="d-block mb-1">Sin usuarios</strong>
                            </div>
                        </td>
                    </tr>

                    <!-- Filas -->
                    <tr th:each="persona : ${personas}">
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar text-white" style="width:38px;height:38px;flex-shrink:0;background:#7c3aed;">
                                    <span th:text="${#strings.substring(persona.username,0,1).toUpperCase()}">U</span>
                                </div>
                                <div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fw-semibold" th:text="${persona.username}">usuario</span>
                                        <!-- Badge: usuario en sesión -->
                                        <span th:if="${session.usuarioSesion != null and session.usuarioSesion.id == persona.id}"
                                              class="chip chip-blue" style="font-size:.7rem;">
                                            <i class="bi bi-person-check-fill"></i> Tú
                                        </span>
                                    </div>
                                    <div class="text-muted small" th:text="${persona.name}">nombre</div>
                                </div>
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell text-muted"
                            th:text="${persona.lastName + (persona.secondLastName != null ? ' ' + persona.secondLastName : '')}">
                            Apellidos
                        </td>
                        <td class="text-center pe-4">
                            <div class="d-flex justify-content-center gap-2">
                                <a th:href="@{/users/{id}/edit(id=${persona.id})}"
                                   class="btn btn-sm btn-outline-secondary" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger js-delete-user"
                                        th:attr="data-form='del-u-' + ${persona.id},
                                                 data-username=${persona.username}">
                                    <i class="bi bi-trash3"></i>
                                </button>
                                <form th:id="'del-u-' + ${persona.id}"
                                      th:action="@{/users/{id}(id=${persona.id})}"
                                      method="POST" style="display:none;">
                                    <input type="hidden" name="_method" value="DELETE"/>
                                </form>
                            </div>
                        </td>
                    </tr>

                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a th:href="@{/welcome}" class="text-muted small">
            <i class="bi bi-arrow-left me-1"></i>Volver al inicio
        </a>
    </div>
</main>

<script>
    document.querySelectorAll('.js-delete-user').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var formId   = this.getAttribute('data-form');
            var username = this.getAttribute('data-username');
            Swal.fire({
                title: '¿Eliminar usuario?',
                html: 'Se eliminará la cuenta de <strong>@' + username + '</strong>. Esta acción no se puede deshacer.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '<i class="bi bi-trash3 me-1"></i>Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: { popup: 'rounded-3', confirmButton: 'btn btn-sm', cancelButton: 'btn btn-sm btn-secondary' },
                buttonsStyling: false
            }).then(function(r) {
                if (r.isConfirmed) document.getElementById(formId).submit();
            });
        });
    });
</script>

<div th:replace="~{fragments/layout :: footer}"></div>
<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
</html>
</file>

<file path="src/main/resources/templates/index.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<head th:replace="~{fragments/layout :: head('Iniciar Sesión')}"></head>

<body style="background: linear-gradient(135deg, #f6f8fd 0%, #f1f5f9 100%); min-height: 100vh;">

<div class="container d-flex align-items-center justify-content-center min-vh-100 py-5 px-3">
    <div class="card p-4 p-sm-5 border-0 shadow-lg" style="max-width: 420px; width: 100%; border-radius: 24px;">
        
        <div class="text-center mb-4">
            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                <!-- Cambiado el fingerprint por el person-circle -->
                <i class="bi bi-person-circle fs-1"></i>
            </div>
            <h4 class="fw-bold text-dark">Bienvenido de nuevo</h4>
            <p class="text-muted small">Ingresa tus credenciales para continuar</p>
        </div>

        <form th:action="@{/}" th:object="${usuarioDto}" method="POST">
            
            <div class="form-floating mb-3">
                <input type="text" class="form-control bg-light" id="username" th:field="*{username}" placeholder="Usuario" th:classappend="${#fields.hasErrors('username')} ? 'is-invalid'">
                <label for="username"><i class="bi bi-person me-2"></i>Usuario</label>
                <div class="invalid-feedback" th:if="${#fields.hasErrors('username')}" th:errors="*{username}"></div>
            </div>

            <!-- Contraseña con ojito usando position-relative -->
            <div class="form-floating mb-4 position-relative">
                <input type="password" class="form-control bg-light" id="password" th:field="*{password}" placeholder="Contraseña" style="padding-right: 2.5rem;" th:classappend="${#fields.hasErrors('password')} ? 'is-invalid'">
                <label for="password"><i class="bi bi-shield-lock me-2"></i>Contraseña</label>
                <!-- Botón del ojito -->
                <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 text-secondary fs-5" id="togglePassword" style="cursor: pointer; z-index: 10;"></i>
                <div class="invalid-feedback" th:if="${#fields.hasErrors('password')}" th:errors="*{password}"></div>
            </div>

            <button type="submit" class="btn btn-brand w-100 py-3 fw-semibold shadow-sm">
                Acceder al Sistema <i class="bi bi-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="text-center mt-4">
            <p class="text-muted small mb-0">¿No tienes cuenta? <a th:href="@{/register/new}" class="text-decoration-none fw-bold text-brand">Regístrate aquí</a></p>
        </div>
    </div>
</div>

<!-- Script para el ojito de la contraseña -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#password');
        
        if(togglePassword && password) {
            togglePassword.addEventListener('click', function () {
                const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
                password.setAttribute('type', type);
                this.classList.toggle('bi-eye');
                this.classList.toggle('bi-eye-slash');
            });
        }
    });
</script>

<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
<!--Hecho con ☕, código y algo de indie rock punk alternativo en la CDMX.-->
</html>
</file>

<file path="src/main/resources/templates/welcome.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<head th:replace="~{fragments/layout :: head('Inicio')}" >
</head>

<body>
<div th:replace="~{fragments/layout :: navbar}"></div>

<main class="container py-5">

    <!-- Saludo -->
    <div class="page-header">
        <h3>
            Hola,
            <span class="text-brand" th:text="${session.usuarioSesion.username}">usuario</span> 👋
        </h3>
        <p>¿Qué quieres hacer hoy?</p>
    </div>

    <!-- Tarjetas de acceso rápido -->
    <div class="row g-4">

        <!-- Mis Contactos -->
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 p-4">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="avatar bg-brand text-white" style="width:48px;height:48px;font-size:1.3rem;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Mis Contactos</h6>
