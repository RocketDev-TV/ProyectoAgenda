<!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  FRAGMENT: scripts                                                   ║
  ║  Uso: <th:block th:replace="~{fragments/layout :: scripts}">        ║
  ║  Incluye: Bootstrap 5 JS + Toast automático de Flash Attributes     ║
  ╚══════════════════════════════════════════════════════════════════════╝
-->
<th:block th:fragment="scripts">
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!--
        Toast automático de Flash Attributes.
        th:inline="javascript" permite leer variables del modelo de Spring directamente.
        Thymeleaf renderiza null cuando la variable no existe → la condición 'if' la descarta.
    -->
    <script th:inline="javascript">
        /*<![CDATA[*/
        (function () {
            var msgSuccess = /*[[${messageConfirmacion}]]*/ null;
            var msgInfo    = /*[[${message}]]*/ null;
            var msgError   = /*[[${messageError}]]*/ null;

            function swalToast(icon, title) {
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: icon,
                    title: title,
                    showConfirmButton: false,
                    timer: 3800,
                    timerProgressBar: true
                });
            }

            if (msgSuccess) swalToast('success', msgSuccess);
            if (msgInfo)    swalToast('success', msgInfo);
            if (msgError)   swalToast('error', msgError);
        })();
        /*]]>*/
    </script>
</th:block>

</body>
</html>
</file>

