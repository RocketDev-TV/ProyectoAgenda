<head th:fragment="head(pageTitle)">
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title th:text="${pageTitle} + ' — Agenda Premium'">Agenda Web</title>

    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <!-- Estilos personalizados -->
    <link th:href="@{/css/style.css}" rel="stylesheet"/>
</head>
<body>

<!-- NAVBAR MAESTRO -->
<nav th:fragment="navbar" class="navbar navbar-expand-lg navbar-premium sticky-top py-3">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" th:href="@{/welcome}">
            <i class="bi bi-layers-half fs-4"></i> Agenda Pro
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <i class="bi bi-grid-3x3-gap-fill fs-4 text-secondary"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-4 gap-3">
                <li class="nav-item"><a class="nav-link" th:href="@{/welcome}"><i class="bi bi-house me-1"></i>Inicio</a></li>
                <li class="nav-item"><a class="nav-link" th:href="@{/contacts}"><i class="bi bi-people me-1"></i>Contactos</a></li>
            </ul>
            <div class="d-flex align-items-center gap-3" th:if="${session.usuarioSesion != null}">
                <div class="d-flex align-items-center gap-2 px-3 py-1 bg-light rounded-pill border">
                    <i class="bi bi-person-circle text-primary fs-5"></i>
                    <span class="fw-semibold text-secondary" th:text="${session.usuarioSesion.username}">User</span>
                </div>
                <a th:href="@{/logout}" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                    <i class="bi bi-box-arrow-right me-1"></i>Salir
                </a>
            </div>
        </div>
    </div>
</nav>

<!-- FOOTER MAESTRO -->
<footer th:fragment="footer" class="bg-white border-top py-4 mt-5 text-center text-muted small">
    <div class="container">
        <p class="mb-0">© 2026 Agenda IPN - UPIICSA.</p>
    </div>
</footer>

<!-- SCRIPTS MAESTROS -->
<th:block th:fragment="scripts">
    <!-- Puente Thymeleaf → JS: pasa flash-attributes como data-attributes (Thymeleaf NO procesa .js externos) -->
    <span id="flash-data"
          th:attr="data-exito=${messageConfirmacion},data-info=${message},data-error=${messageError}"
          hidden></span>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script th:src="@{/js/main.js}"></script>
</th:block>

</body>
</html>
</file>

<file path="src/main/resources/templates/register/new.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<head th:replace="~{fragments/layout :: head('Crear Cuenta')}"></head>

<!-- Fondo cambiado para que haga match con el Login -->
<body style="background: linear-gradient(135deg, #f6f8fd 0%, #f1f5f9 100%); min-height:100vh;">

<div class="container d-flex align-items-center justify-content-center min-vh-100 py-5 px-3">
    <div style="width:100%; max-width:500px;">

        <!-- Card sin el header suelto, todo encapsulado -->
        <div class="card p-4 p-sm-5 border-0 shadow-lg" style="border-radius: 24px;">
            
            <div class="text-center mb-4">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                    <i class="bi bi-person-plus-fill fs-1"></i>
                </div>
                <h4 class="fw-bold text-dark">Crear Cuenta</h4>
                <p class="text-muted small">Todos los campos marcados con * son obligatorios</p>
            </div>

            <form th:action="@{/register}" th:object="${registerUserDto}" method="POST">

                <!-- Nombre -->
                <div class="mb-3">
                    <label for="name" class="form-label text-muted small fw-semibold">
                        <i class="bi bi-person text-brand me-1"></i>Nombre *
                    </label>
                    <input type="text" id="name" th:field="*{name}" class="form-control bg-light" th:classappend="${#fields.hasErrors('name')} ? ' is-invalid'" placeholder="ej. María"/>
                    <div class="invalid-feedback" th:if="${#fields.hasErrors('name')}" th:errors="*{name}"></div>
                </div>

                <!-- Apellidos -->
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label for="lastName" class="form-label text-muted small fw-semibold">1er Apellido *</label>
                        <input type="text" id="lastName" th:field="*{lastName}" class="form-control bg-light" th:classappend="${#fields.hasErrors('lastName')} ? ' is-invalid'" placeholder="ej. García"/>
                        <div class="invalid-feedback" th:if="${#fields.hasErrors('lastName')}" th:errors="*{lastName}"></div>
                    </div>
                    <div class="col-sm-6">
                        <!-- Texto acortado para que no se desborde -->
                        <label for="secondLastName" class="form-label text-muted small fw-semibold">2do Apellido <span class="fw-normal">(opcional)</span></label>
                        <input type="text" id="secondLastName" th:field="*{secondLastName}" class="form-control bg-light" placeholder="ej. López"/>
                    </div>
                </div>

                <hr class="my-4 border-light"/>

                <!-- Username -->
                <div class="mb-3">
                    <label for="username" class="form-label text-muted small fw-semibold">
                        <i class="bi bi-at text-brand me-1"></i>Nombre de Usuario *
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-at"></i></span>
                        <input type="text" id="username" th:field="*{username}" class="form-control bg-light border-start-0" th:classappend="${#fields.hasErrors('username')} ? ' is-invalid'" placeholder="mi_usuario" autocomplete="username"/>
                        <div class="invalid-feedback" th:if="${#fields.hasErrors('username')}" th:errors="*{username}"></div>
                    </div>
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <label for="password" class="form-label text-muted small fw-semibold">
                        <i class="bi bi-shield-lock text-brand me-1"></i>Contraseña *
                    </label>
                    <!-- Wrapper relativo para el ojito -->
                    <div class="position-relative">
                        <input type="password" id="password" th:field="*{password}" class="form-control bg-light" style="padding-right: 2.5rem;" th:classappend="${#fields.hasErrors('password')} ? ' is-invalid'" placeholder="Mínimo 6 caracteres" autocomplete="new-password"/>
                        <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 text-secondary fs-5" id="togglePassword" style="cursor: pointer; z-index: 10;"></i>
                        <div class="invalid-feedback" th:if="${#fields.hasErrors('password')}" th:errors="*{password}"></div>
                    </div>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-3 fw-semibold shadow-sm">
                    <i class="bi bi-person-check me-2"></i>Crear Cuenta
                </button>
            </form>

            <div class="text-center mt-4">
                <p class="text-muted small mb-0">¿Ya tienes cuenta? <a th:href="@{/}" class="text-decoration-none fw-bold text-brand">Inicia sesión</a></p>
            </div>
        </div>

    </div>
</div>

<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
</html>
</file>

