<main class="container py-4">

    <!-- Header -->
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-3 page-header">
        <div>
            <h3>
                <i class="bi bi-telephone-inbound-fill text-brand me-2"></i>Medios de Contacto
            </h3>
            <p>
                Contacto
                <span class="chip chip-blue" th:text="'#' + ${idContact}">—</span>
            </p>
        </div>
        <a th:href="@{/contacts/{id}/media/create(id=${idContact})}" class="btn btn-brand">
            <i class="bi bi-plus-circle-fill me-2"></i>Agregar Medio
        </a>
    </div>

    <!-- Tabla de medios -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th class="ps-4" style="width:40%;">Tipo</th>
                        <th>Valor / Cuenta</th>
                        <th class="text-center pe-4" style="width:130px;">Acciones</th>
                    </tr>
                    </thead>
                    <tbody>

                    <!-- Sin medios -->
                    <tr th:if="${#lists.isEmpty(mediaList)}">
                        <td colspan="3">
                            <div class="empty-state">
                                <i class="bi bi-telephone-x"></i>
                                <strong class="d-block mb-1">Sin medios registrados</strong>
                                <span class="small">Agrega correos, teléfonos o redes sociales.</span>
                            </div>
                        </td>
                    </tr>

                    <!-- Filas -->
                    <tr th:each="media : ${mediaList}">
                        <td class="ps-4">
                            <th:block th:switch="${media.idType}">
                                <span th:case="1" class="chip chip-blue">
                                    <i class="bi bi-envelope-fill"></i> Correo Electrónico
                                </span>
                                <span th:case="2" class="chip chip-green">
                                    <i class="bi bi-telephone-fill"></i> Número Telefónico
                                </span>
                                <span th:case="3" class="chip chip-purple">
                                    <i class="bi bi-instagram"></i> Instagram
                                </span>
                                <span th:case="*" class="chip chip-gray">
                                    <i class="bi bi-chat-dots"></i>
                                    Tipo <span th:text="${media.idType}"></span>
                                </span>
                            </th:block>
                        </td>
                        <td class="fw-semibold" th:text="${media.value}">valor</td>
                        <td class="text-center pe-4">
                            <div class="d-flex justify-content-center gap-2">
                                <!-- Editar -->
                                <a th:href="@{/contacts/{ic}/media/{id}/edit(ic=${idContact},id=${media.id})}"
                                   class="btn btn-sm btn-outline-secondary" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <!-- Eliminar -->
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger js-delete-media"
                                        th:attr="data-form='del-m-' + ${media.id},
                                                 data-val=${media.value}">
                                    <i class="bi bi-trash3"></i>
                                </button>
                                <form th:id="'del-m-' + ${media.id}"
                                      th:action="@{/contacts/{ic}/media/{id}(ic=${idContact},id=${media.id})}"
                                      method="POST" style="display:none;">
                                    <input type="hidden" name="_method" value="DELETE"/>
                                </form>
                            </div>
                        </td>
                    </tr>

                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a th:href="@{/contacts}" class="text-muted small">
            <i class="bi bi-arrow-left me-1"></i>Volver a Contactos
        </a>
    </div>
</main>

<!-- SweetAlert2 ya está en <head> via layout -->
<script>
    document.querySelectorAll('.js-delete-media').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var formId = this.getAttribute('data-form');
            var val    = this.getAttribute('data-val');
            Swal.fire({
                title: '¿Eliminar medio?',
                html: 'Se eliminará el registro: <strong>' + val + '</strong>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: '<i class="bi bi-trash3 me-1"></i>Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true,
                customClass: { popup: 'rounded-3', confirmButton: 'btn btn-sm', cancelButton: 'btn btn-sm btn-secondary' },
                buttonsStyling: false
            }).then(function(r) {
                if (r.isConfirmed) document.getElementById(formId).submit();
            });
        });
    });
</script>

<div th:replace="~{fragments/layout :: footer}"></div>
<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
</html>
</file>

