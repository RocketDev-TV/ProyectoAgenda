<file path="src/main/resources/templates/fragments/layout.html">
<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  FRAGMENT: head(pageTitle)                                   ║
  ║  Uso: <head th:replace="~{fragments/layout :: head('Título')}">  ║
  ║  Incluye: Bootstrap 5 CSS · Bootstrap Icons · SweetAlert2   ║
  ╚══════════════════════════════════════════════════════════════╝
-->
<head th:fragment="head(pageTitle)">
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title th:text="${pageTitle} + ' — Agenda Web'">Agenda Web</title>

    <!-- ① Bootstrap 5.3 CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>

    <!-- ② Bootstrap Icons 1.11 -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>

    <!-- ③ SweetAlert2 — va en <head> para estar disponible en scripts de confirmación -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <!-- ④ Estilos personalizados -->
    <style>
        /* ── Variables ─────────────────────────────── */
        :root {
            --brand:        #2563eb;   /* Blue-600  */
            --brand-dark:   #1d4ed8;   /* Blue-700  */
            --brand-light:  #dbeafe;   /* Blue-100  */
            --surface:      #f8fafc;   /* Slate-50  */
            --card-shadow:  0 1px 3px rgba(0,0,0,.08), 0 8px 24px rgba(37,99,235,.06);
            --nav-bg:       #0f172a;   /* Slate-900 */
            --text:         #0f172a;
            --muted:        #64748b;
        }

        /* ── Base ───────────────────────────────────── */
        body {
            background-color: var(--surface);
            color: var(--text);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        main { flex: 1; }

        /* ── Navbar ─────────────────────────────────── */
        .app-navbar {
            background-color: var(--nav-bg);
            border-bottom: 1px solid rgba(255,255,255,.06);
        }
        .app-navbar .navbar-brand {
            font-weight: 700;
            font-size: 1.15rem;
            letter-spacing: -.3px;
            color: #fff !important;
        }
        .app-navbar .nav-link {
            color: rgba(255,255,255,.65) !important;
            font-size: .875rem;
            font-weight: 500;
            padding: .5rem .75rem;
            border-radius: 6px;
            transition: color .15s, background .15s;
        }
        .app-navbar .nav-link:hover,
        .app-navbar .nav-link.active {
            color: #fff !important;
            background-color: rgba(255,255,255,.08);
        }
        .app-navbar .nav-divider {
            width: 1px; height: 20px;
            background: rgba(255,255,255,.15);
            align-self: center;
        }

        /* ── Cards ──────────────────────────────────── */
        .card {
            border: 1px solid rgba(0,0,0,.06);
            border-radius: 12px;
            box-shadow: var(--card-shadow);
        }
        .card-header {
            background-color: var(--brand) !important;
            color: #fff;
            border-radius: 11px 11px 0 0 !important;
            border-bottom: none;
            padding: 1rem 1.25rem;
        }
        .card-header h5, .card-header h6 { margin-bottom: 0; font-weight: 600; }

        /* ── Buttons ─────────────────────────────────── */
        .btn { border-radius: 8px; font-weight: 500; }
        .btn-brand {
            background-color: var(--brand);
            border-color: var(--brand);
            color: #fff;
        }
        .btn-brand:hover, .btn-brand:focus {
            background-color: var(--brand-dark);
            border-color: var(--brand-dark);
            color: #fff;
        }
        .btn-outline-brand {
            border-color: var(--brand);
            color: var(--brand);
        }
        .btn-outline-brand:hover {
            background-color: var(--brand);
            color: #fff;
        }

        /* ── Tables ──────────────────────────────────── */
        .table thead th {
            font-size: .75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: var(--muted);
            background-color: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
            padding: .875rem 1rem;
        }
        .table tbody td {
            vertical-align: middle;
            padding: .875rem 1rem;
            border-color: #f1f5f9;
        }
        .table-hover tbody tr:hover { background-color: #eff6ff; }

        /* ── Form controls ───────────────────────────── */
        .form-control, .form-select {
            border-color: #e2e8f0;
            border-radius: 8px;
            font-size: .9rem;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 3px rgba(37,99,235,.15);
        }
        .form-label { font-weight: 500; font-size: .875rem; margin-bottom: .375rem; }

        /* ── Badges / Chips ──────────────────────────── */
        .chip {
            display: inline-flex; align-items: center; gap: .35rem;
            padding: .25rem .65rem;
            border-radius: 9999px;
            font-size: .78rem;
            font-weight: 500;
        }
        .chip-blue   { background: var(--brand-light); color: var(--brand-dark); }
        .chip-green  { background: #dcfce7; color: #166534; }
        .chip-red    { background: #fee2e2; color: #991b1b; }
        .chip-purple { background: #ede9fe; color: #6d28d9; }
        .chip-gray   { background: #f1f5f9; color: #475569; }

        /* ── Footer ──────────────────────────────────── */
        .app-footer {
            background-color: #fff;
            border-top: 1px solid #e2e8f0;
            padding: .875rem 0;
            font-size: .8rem;
            color: var(--muted);
            text-align: center;
        }

        /* ── Utilities ───────────────────────────────── */
        .text-brand  { color: var(--brand) !important; }
        .bg-brand    { background-color: var(--brand) !important; }
        .avatar {
            width: 36px; height: 36px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: .85rem;
        }
        .page-header { margin-bottom: 1.75rem; }
        .page-header h3 { font-weight: 700; margin-bottom: .2rem; }
        .page-header p  { color: var(--muted); font-size: .875rem; margin: 0; }
        .empty-state { padding: 3.5rem 1rem; text-align: center; color: var(--muted); }
        .empty-state i { font-size: 2.5rem; opacity: .3; display: block; margin-bottom: .75rem; }
    </style>
</head>

<body>

