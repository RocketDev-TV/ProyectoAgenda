<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="es">

<head th:replace="~{fragments/layout :: head('Crear Cuenta')}">
</head>

<body style="background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #1e40af 100%); min-height:100vh;">

<div class="d-flex align-items-center justify-content-center min-vh-100 py-5 px-3">
    <div style="width:100%; max-width:500px;">

        <!-- Brand -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white mb-3"
                 style="width:64px; height:64px; box-shadow: 0 8px 24px rgba(0,0,0,.3);">
                <i class="bi bi-person-plus-fill fs-3 text-brand"></i>
            </div>
            <h1 class="text-white fw-bold fs-3 mb-1">Crear Cuenta</h1>
            <p class="text-white-50 small mb-0">Completa el formulario para registrarte</p>
        </div>

        <!-- Card -->
        <div class="card p-4 p-sm-5">
            <h5 class="fw-bold mb-1">Datos de Registro</h5>
            <p class="text-muted small mb-4">Todos los campos marcados con * son obligatorios</p>

            <form th:action="@{/register}" th:object="${registerUserDto}" method="POST">

                <!-- Nombre -->
                <div class="mb-3">
                    <label for="name" class="form-label">
                        <i class="bi bi-person text-brand me-1"></i>Nombre *
                    </label>
                    <input type="text" id="name"
                           th:field="*{name}"
                           class="form-control"
                           th:classappend="${#fields.hasErrors('name')} ? ' is-invalid'"
                           placeholder="ej. María"/>
                    <div class="invalid-feedback" th:if="${#fields.hasErrors('name')}"
                         th:errors="*{name}"></div>
                </div>

                <!-- Apellidos -->
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <label for="lastName" class="form-label">Primer Apellido *</label>
                        <input type="text" id="lastName"
                               th:field="*{lastName}"
                               class="form-control"
                               th:classappend="${#fields.hasErrors('lastName')} ? ' is-invalid'"
                               placeholder="ej. García"/>
                        <div class="invalid-feedback" th:if="${#fields.hasErrors('lastName')}"
                             th:errors="*{lastName}"></div>
                    </div>
                    <div class="col-sm-6">
                        <label for="secondLastName" class="form-label">
                            Segundo Apellido <span class="text-muted fw-normal">(opcional)</span>
                        </label>
                        <input type="text" id="secondLastName"
                               th:field="*{secondLastName}"
                               class="form-control"
                               placeholder="ej. López"/>
                    </div>
                </div>

                <hr class="my-4"/>

                <!-- Username -->
                <div class="mb-3">
                    <label for="username" class="form-label">
                        <i class="bi bi-at text-brand me-1"></i>Nombre de Usuario *
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-at"></i>
                        </span>
                        <input type="text" id="username"
                               th:field="*{username}"
                               class="form-control border-start-0"
                               th:classappend="${#fields.hasErrors('username')} ? ' is-invalid'"
                               placeholder="mi_usuario"
                               autocomplete="username"/>
                        <div class="invalid-feedback" th:if="${#fields.hasErrors('username')}"
                             th:errors="*{username}"></div>
                    </div>
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <label for="password" class="form-label">
                        <i class="bi bi-shield-lock text-brand me-1"></i>Contraseña *
                    </label>
                    <input type="password" id="password"
                           th:field="*{password}"
                           class="form-control"
                           th:classappend="${#fields.hasErrors('password')} ? ' is-invalid'"
                           placeholder="Mínimo 6 caracteres"
                           autocomplete="new-password"/>
                    <div class="invalid-feedback" th:if="${#fields.hasErrors('password')}"
                         th:errors="*{password}"></div>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-2 fw-semibold">
                    <i class="bi bi-person-check me-2"></i>Crear Cuenta
                </button>
            </form>

            <hr class="my-4"/>

            <p class="text-center text-muted small mb-0">
                ¿Ya tienes cuenta?
                <a th:href="@{/}" class="fw-semibold text-brand">Inicia sesión</a>
            </p>
        </div>

    </div>
</div>

<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
</html>
</file>

