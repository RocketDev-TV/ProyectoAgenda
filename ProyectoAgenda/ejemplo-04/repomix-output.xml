            <h5 class="fw-bold mb-1">Bienvenido 👋</h5>
            <p class="text-muted small mb-4">Ingresa tus credenciales para continuar</p>

            <form th:action="@{/}" th:object="${usuarioDto}" method="POST">

                <!-- Usuario -->
                <div class="mb-3">
                    <label for="username" class="form-label">
                        <i class="bi bi-person text-brand me-1"></i>Usuario
                    </label>
                    <input type="text" id="username"
                           th:field="*{username}"
                           class="form-control form-control-lg"
                           th:classappend="${#fields.hasErrors('username')} ? ' is-invalid'"
                           placeholder="tu_usuario"
                           autocomplete="username" autofocus/>
                    <div class="invalid-feedback" th:if="${#fields.hasErrors('username')}"
                         th:errors="*{username}"></div>
                </div>

                <!-- Contraseña -->
                <div class="mb-4">
                    <label for="password" class="form-label">
                        <i class="bi bi-lock text-brand me-1"></i>Contraseña
                    </label>
                    <input type="password" id="password"
                           th:field="*{password}"
                           class="form-control form-control-lg"
                           th:classappend="${#fields.hasErrors('password')} ? ' is-invalid'"
                           placeholder="••••••••"
                           autocomplete="current-password"/>
                    <div class="invalid-feedback" th:if="${#fields.hasErrors('password')}"
                         th:errors="*{password}"></div>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-2 fw-semibold fs-6">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                </button>
            </form>

            <hr class="my-4"/>

            <p class="text-center text-muted small mb-0">
                ¿No tienes cuenta?
                <a th:href="@{/register/new}" class="fw-semibold text-brand">Regístrate aquí</a>
            </p>
        </div>

    </div>
</div>

<th:block th:replace="~{fragments/layout :: scripts}"></th:block>
</body>
</html>
</file>

